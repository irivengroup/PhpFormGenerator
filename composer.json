{
  "name": "iriven/php-form-generator",
  "description": "Enterprise PHP form framework with legacy field types, fieldsets, nested forms and collections.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.0",
    "rector/rector": "^1.1",
    "infection/infection": "^0.29"
  },
  "autoload": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --colors=never",
    "analyse": "vendor/bin/phpstan analyse src tests",
    "fix": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
    "mutate": "vendor/bin/infection --threads=max"
  },
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    },
    "sort-packages": true
  }
}
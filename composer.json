{
  "name": "iriven/php-form-generator",
  "description": "Enterprise form framework V3.2 production hardening starter",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.12",
    "rector/rector": "^1.2",
    "infection/infection": "^0.29"
  },
  "autoload": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Iriven\\PhpFormGenerator\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors=always",
    "analyse": "phpstan analyse",
    "refactor": "rector process",
    "mutate": "infection --threads=max --min-msi=60 --min-covered-msi=70",
    "lint": "php -l src/Application/FormFactory.php && php -l src/Domain/Form/Form.php && php -l src/Presentation/Html/HtmlRenderer.php",
    "qa": [
      "@lint",
      "@analyse",
      "@test"
    ]
  }
}
